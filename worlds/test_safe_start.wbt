#VRML_SIM R2025a utf8

EXTERNPROTO "../protos/SimpleRosBot.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"

WorldInfo {
  coordinateSystem "NUE"
  basicTimeStep 32
  title "Safe Start Motor Test World"
}

# Good default frame: angled top view of full arena, robot, pillars and walls.
Viewpoint {
  orientation -0.577350269 0.577350269 0.577350269 2.0944
  position 6 7 8
}
TexturedBackground {
}
TexturedBackgroundLight {
}
DirectionalLight {
  direction -0.4 -1 -0.4
  intensity 1.2
}

# The robot starts at the center, far away from every wall.
SimpleRosBot {
  translation 0 0.14 0
  rotation 0 1 0 0
  controller "rosbot_navigation"
}

Solid {
  name "floor"
  translation 0 -0.025 0
  children [
    Shape {
      appearance PBRAppearance { baseColor 0.55 0.55 0.55 roughness 1 }
      geometry Box { size 14 0.05 14 }
    }
  ]
  boundingObject Box { size 14 0.05 14 }
}

# Thick fixed walls. They are static Solids with boundingObjects and no Physics node.
Solid { name "north wall" translation 0 0.5 -7 children [ Shape { appearance PBRAppearance { baseColor 0.75 0.75 0.75 roughness 0.8 } geometry Box { size 14.4 1.0 0.45 } } ] boundingObject Box { size 14.4 1.0 0.45 } }
Solid { name "south wall" translation 0 0.5 7 children [ Shape { appearance PBRAppearance { baseColor 0.75 0.75 0.75 roughness 0.8 } geometry Box { size 14.4 1.0 0.45 } } ] boundingObject Box { size 14.4 1.0 0.45 } }
Solid { name "west wall" translation -7 0.5 0 children [ Shape { appearance PBRAppearance { baseColor 0.75 0.75 0.75 roughness 0.8 } geometry Box { size 0.45 1.0 14.4 } } ] boundingObject Box { size 0.45 1.0 14.4 } }
Solid { name "east wall" translation 7 0.5 0 children [ Shape { appearance PBRAppearance { baseColor 0.75 0.75 0.75 roughness 0.8 } geometry Box { size 0.45 1.0 14.4 } } ] boundingObject Box { size 0.45 1.0 14.4 } }

Solid {
  name "blue pillar"
  translation -3 0.4 -3
  children [ Shape { appearance PBRAppearance { baseColor 0 0.05 1 roughness 0.5 } geometry Cylinder { radius 0.18 height 0.8 } } ]
  boundingObject Cylinder { radius 0.18 height 0.8 }
}
Solid {
  name "yellow pillar"
  translation 3 0.4 -3
  children [ Shape { appearance PBRAppearance { baseColor 1 0.85 0 roughness 0.5 } geometry Cylinder { radius 0.18 height 0.8 } } ]
  boundingObject Cylinder { radius 0.18 height 0.8 }
}
Solid {
  name "green forbidden ground"
  translation 0 0.006 3
  children [ Shape { appearance PBRAppearance { baseColor 0 0.75 0.1 roughness 1 } geometry Box { size 1.8 0.01 1.3 } } ]
}
